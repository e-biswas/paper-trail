# Paper Trail — environment variables
#
# Copy this file to `.env` and fill in the secrets.
# `.env` is gitignored. Never commit real values.

# ──────────────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic API key for Claude Opus 4.7. Hackathon credits apply.
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token for the bot account that opens demo PRs.
# Scope needed: `repo` (full). Fine-grained tokens also work, scoped to the
# demo fork only.
GITHUB_TOKEN=ghp_...

# Bot account owner + repo where demo PRs are opened.
GITHUB_BOT_OWNER=paper-trail
GITHUB_BOT_REPO=muchlinski-demo

# ──────────────────────────────────────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR. Default INFO.
LOG_LEVEL=INFO

# Override the backup fixture's bot repo (if different from the primary).
# If unset, falls back to GITHUB_BOT_REPO above.
# GITHUB_BOT_REPO_ISIC=isic-demo

# Absolute path where fixture stage scripts materialize the staged repo.
# Default: /tmp/<fixture>-demo. Override for CI or alternative tmp dirs.
# REPRO_DEMO_TARGET=/tmp/muchlinski-demo

# Paper ingester cache directory. Default: ~/.cache/paper-trail/papers/.
# REPRO_PAPER_CACHE=/tmp/repro-paper-cache

# Claude Agent SDK optional knobs:
# CLAUDE_CODE_USE_BEDROCK=0
# CLAUDE_CODE_USE_VERTEX=0
